// filepath: /c:/Users/Renildo/Desktop/Yumma CSS/website/yumma-css-docs/src/components/Palette2.astro
import tinycolor from "tinycolor2";

interface ColorItem {
  name: string;
  color: string;
}

interface PaletteProps {
  data: ColorItem[];
  percentage?: number;
}

const { data, percentage = 10 } = Astro.props as PaletteProps;

// Helper function to mix colors
const mixColors = (color1: string, color2: string, weight: number): string => {
  return tinycolor.mix(color1, color2, weight).toHexString();
};

// Generate shades for the new numbering system (1–12)
const generateShades = (color: string): string[] => {
  const shades: string[] = [];
  for (let i = 1; i <= 6; i++) {
    shades.push(mixColors(color, "white", (7 - i) * percentage)); // Light shades (1–6)
  }

  shades.push(color); // Base color at position 7

  for (let i = 1; i <= 6; i++) {
    shades.push(mixColors(color, "black", i * percentage)); // Dark shades (8–12)
  }

  return shades;
};
---

<div class="d-f fd-c">
  <!-- Header Row with Numbers -->
  <div class="d-g fs-xs shadeNumbers ta-c">
    <div></div>
    {
      Array.from({ length: 13 }, (_, i) => (
        <div>{i === 6 ? "Base" : i < 6 ? i + 1 : i}</div>
      ))
    }
  </div>

  <!-- Colors Row -->
  {
    data.map((colorItem) => {
      const shades = generateShades(colorItem.color);
      return (
        <div class="ai-c colorRow d-g g-1">
          <div class="colorName">{colorItem.name}</div>
          {shades.map((shade, index) => (
            <div
              class="colorSwatch h-10 w-full"
              style={`background-color: ${shade}`}
              title={index === 6 ? "Base Color" : `${colorItem.color}`}
            />
          ))}
        </div>
      );
    })
  }
</div>

<style>
  .shadeNumbers {
    grid-template-columns: 40px repeat(13, 1fr);
  }

  .colorRow {
    grid-template-columns: 40px repeat(13, 1fr);
  }

  .colorName {
    writing-mode: vertical-lr;
    font-size: 0.875rem;
    white-space: nowrap;
  }

  .colorSwatch {
    border: 2px solid transparent;
  }

  .colorSwatch:hover {
    border-color: light-dark(#202020, transparent);
  }

  @media (max-width: 768px) {
    .shadeNumbers {
      display: none;
    }

    .colorRow {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .colorName {
      writing-mode: horizontal-tb;
      text-align: center;
      font-size: 1rem;
    }

    .colorSwatch {
      width: 100%;
      height: 50px;
    }
  }
</style>
