---
import type { Props } from "@astrojs/starlight/props";

const { title, description } = Astro.props.entry.data;
---

<Fragment>
  <h1 id="_top">{title}</h1>
  {
    description && (
      <p class="description lh-4 mt-2" style="color: light-dark(var(--sl-color-gray-3), var(--sl-color-gray-2));">
        {description}
      </p>
    )
  }
</Fragment>
