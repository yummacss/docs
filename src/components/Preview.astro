---
import { Code, Tabs, TabItem } from "@astrojs/starlight/components";

interface PreviewProps {
  data: string;
  useScroll?: boolean;
  useCenter?: boolean;
  useExternal?: string;
  useFrame?: "none" | "code" | "terminal" | "auto";
  useHeight?: string;
  useMarks?: string[];
  usePadding?: boolean;
  useTabs?: boolean;
  useTitle?: string;
  useVersion?: string;
  useWrap?: boolean;
}

const {
  data,
  useScroll = false,
  useCenter = false,
  useExternal = "",
  useFrame = "none",
  useHeight = "300px",
  useMarks = [],
  usePadding = false,
  useTabs = false,
  useTitle = "",
  useVersion = "",
  useWrap = false,
} = Astro.props as PreviewProps;

const newContainer = (
  stylesheet: string,
  flex: string,
  useCenter: boolean,
  usePadding: boolean,
  useScroll: boolean,
  newCode: string
) => `
  <html>
    <head>
      <link rel="stylesheet" href="${stylesheet}">
      <style>
        #preview-tab {
          ${flex} 
          justify-content: ${useCenter ? "center" : "flex-start"}; 
          align-items: ${useCenter ? "center" : "flex-start"};
          ${usePadding ? "padding: 12px 14px;" : ""}
          ${useScroll ? "overflow-y: hidden;" : ""}
        }
        ${useScroll ? "body { overflow-y: hidden; }" : ""}
      </style>
    </head>
    <body>
      <div id="preview-tab">${newCode}</div>
    </body>
  </html>
`;

const stylesheet =
  useExternal ||
  `https://cdn.jsdelivr.net/gh/yumma-lib/yumma-css@${useVersion}/dist/yumma.css`;

const flexbox = useCenter ? "display: flex;" : "";
const newCode = data;
const container = newContainer(
  stylesheet,
  flexbox,
  useCenter,
  usePadding,
  useScroll,
  newCode
);
---

<div>
  {
    useTabs ? (
      <Tabs>
        <TabItem icon="seti:video" label="Preview">
          <iframe
            class="preview"
            loading="lazy"
            sandbox="allow-scripts allow-same-origin"
            srcdoc={container}
            style={`height: ${useHeight};`}
          />
        </TabItem>
        <TabItem icon="seti:html" label="Code">
          <div>
            <Code
              code={newCode}
              frame={useFrame}
              lang="html"
              mark={useMarks}
              title={useTitle}
              wrap={useWrap}
            />
          </div>
        </TabItem>
      </Tabs>
    ) : (
      <div>
        <iframe
          class="preview"
          loading="lazy"
          sandbox="allow-scripts allow-same-origin"
          srcdoc={container}
          style={`height: ${useHeight};`}
        />
        <div class="codeContainer">
          <Code code={newCode} lang="html" mark={useMarks} wrap={useWrap} />
        </div>
      </div>
    )
  }
</div>

<style>
  .preview {
    background-color: light-dark(#f5f6f8, #1f212a);
    border: 1px solid light-dark(#eceef2, #2e313f);
    overflow-y: auto;
    width: 100%;
  }
</style>
