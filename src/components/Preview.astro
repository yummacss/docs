---
import { Code, Tabs, TabItem } from "@astrojs/starlight/components";
import generateContainer from "../container";

interface PreviewProps {
  data: string;
  useFrame?: "none" | "code" | "terminal" | "auto";
  useMarks?: string[];
  usePadding?: boolean;
  useTabs?: boolean;
  useTitle?: string;
  useVersion?: string;
  useWrap?: boolean;
}

const {
  data,
  useFrame = "none",
  useMarks = [],
  useTabs = false,
  useTitle = "",
  useVersion = "latest",
  useWrap = false,
} = Astro.props as PreviewProps;

const stylesheet = `https://cdn.jsdelivr.net/gh/yumma-lib/yumma-css@${useVersion}/dist/yumma.css`;

const code = generateContainer({ data, stylesheet });
---

<div>
  {
    useTabs ? (
      <Tabs>
        <TabItem icon="seti:video" label="Preview">
          <div class="ai-c d-f jc-c preview w-full">
            <iframe
              class="preview"
              loading="lazy"
              sandbox="allow-scripts allow-same-origin"
              srcdoc={code}
            />
          </div>
        </TabItem>
        <TabItem icon="seti:html" label="Code">
          <Code
            code={data}
            frame={useFrame}
            lang="html"
            mark={useMarks}
            title={useTitle}
            wrap={useWrap}
          />
        </TabItem>
      </Tabs>
    ) : (
      <div class="d-f fd-c">
        <div>
          <iframe
            class="ai-c d-f jc-c preview w-full"
            loading="lazy"
            sandbox="allow-scripts allow-same-origin"
            srcdoc={code}
          />
        </div>
        <Code code={data} lang="html" mark={useMarks} wrap={useWrap} />
      </div>
    )
  }
</div>

<style>
  .preview {
    background: light-dark(var(--sl-color-black), var(--sl-color-gray-6));
    border: 1px solid light-dark(var(--sl-color-gray-6), var(--ec-brdCol));
  }
</style>
