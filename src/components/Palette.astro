---
import tinycolor from "tinycolor2";

interface ColorItem {
  name: string;
  color: string;
}

interface PaletteProps {
  data: ColorItem[];
}

const { data } = Astro.props as PaletteProps;

const mixColors = (color1: string, color2: string, weight: number): string => {
  return tinycolor.mix(color1, color2, weight).toHexString();
};

const generateShades = (color: string): string[] => {
  const shades: string[] = [];
  for (let i = 6; i >= 1; i--) {
    shades.push(mixColors(color, "white", i * 10));
  }

  shades.push(color);
  for (let i = 1; i <= 6; i++) {
    shades.push(mixColors(color, "black", i * 10));
  }

  return shades;
};

---

<style>
  .paletteContainer {
    display: flex;
    flex-direction: column;
    
  }

  .shadeNumbers {
    display: grid;
    grid-template-columns: 40px repeat(13, 1fr);
    font-size: 0.75rem;
    color: #888;
    text-align: center;
  }

  .colorRow {
    display: grid;
    grid-template-columns: 40px repeat(13, 1fr);
    align-items: center;
    gap: 0.25rem;
  }

  .colorName {
    writing-mode: vertical-lr;
    text-align: left;
    font-size: 0.875rem;
    color: #555;
    white-space: nowrap;
  }

  .colorSwatch {
    width: 100%;
    height: 40px;
    border: 2px solid transparent;
  }

  .colorSwatch:hover {
    border-color: #202020;
  }
</style>

<div class="shadeNumbers">
  <div></div>
  {Array.from({ length: 13 }, (_, i) => (
    <div>{i === 6 ? "B" : (i < 6 ? i + 1 : i - 6)}</div>
  ))}
</div>

  {data.map((colorItem) => {
    const shades = generateShades(colorItem.color);
    return (
      <div class="colorRow not-content">
        <!-- Vertical color name -->
        <div class="colorName">{colorItem.name}</div>
        <!-- Color swatches -->
        {shades.map((shade, index) => (
          <div 
            class="colorSwatch" 
            style={`background-color: ${shade}`}
            title={index === 6 ? "Base Color" : `Shade ${index < 6 ? index + 1 : index - 6}`}
          />
        ))}
      </div>
    );
  })}
</div>
