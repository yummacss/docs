---
export interface Props {
  name: string;
}
const { name } = Astro.props;
---

<div class="max-h-90 o-y-auto mb-5" data-name={name}>
  <table>
    <thead>
      <tr>
        <th class="fs-md fw-600">Utility</th>
        <th class="fs-md fw-600">Properties</th>
      </tr>
    </thead>
    <tbody id="data-container">
      <tr>
        <td colspan="2" id="loading-state"> Loading classes... </td>
      </tr>
    </tbody>
  </table>
</div>

<script type="module">
  document.addEventListener("DOMContentLoaded", async () => {
    const container = document.currentScript.closest("div");
    const name = container.dataset.name;
    const tbody = document.getElementById("data-container");
    const loader = document.getElementById("loading-state");

    try {
      const slug = encodeURIComponent(name);
      const response = await fetch(`https://get.yummacss.com/api/${slug}`);

      if (!response.ok) {
        throw new Error(`API responded with status ${response.status}`);
      }

      const data = await response.json();
      loader.remove();

      data.forEach((item) => {
        const row = document.createElement("tr");
        row.innerHTML = `
          <td><p class="fs-sm">${item.utility}</p></td>
          <td><code>${item.property.join(" ")}</code></td>
        `;
        tbody.appendChild(row);
      });
    } catch (error) {
      loader.innerHTML = `Failed to load data. ${error.message}`;
      console.error("Client-side fetch error:", error);
    }
  });
</script>
