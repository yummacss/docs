---
export interface Props {
  name: string;
}

let data = [];
let errMsg = "";

try {
  if (!Astro.props.name || typeof Astro.props.name !== "string") {
    throw new Error("Invalid or missing 'name' property");
  }

  const slug = encodeURIComponent(Astro.props.name);
  const res = await fetch(`https://get.yummacss.com/api/${slug}`);

  if (!res.ok) {
    throw new Error(`The API responded with: ${res.status}`);
  }

  data = await res.json();
} catch (err) {
  errMsg = err instanceof Error ? err.message : String(err);
  console.error("Failed to fetch data:", err);
}
---

<div class="max-h-90 o-y-auto mb-5">
  <table>
    <thead>
      <tr>
        <th class="fs-md fw-600">Utility</th>
        <th class="fs-md fw-600">Properties</th>
      </tr>
    </thead>
    <tbody>
      {
        data.length > 0 ? (
          data.map((item: { utility: string; property: string[] }) => (
            <tr>
              <td>
                <p class="fs-sm">{item.utility}</p>
              </td>
              <td>
                <code>{item.property.join(" ")}</code>
              </td>
            </tr>
          ))
        ) : (
          <td colspan="2" title={errMsg}>
            Failed to load data. Please try again later.
          </td>
        )
      }
    </tbody>
  </table>
</div>
