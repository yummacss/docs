---
interface Props {
  description: string;
}

const { description } = Astro.props;
---

<article class="ai-c d-f fd-c g-2 ta-c">
  <img
    class="w-60"
    src="https://www.yummacss.com/assets/images/yummacss.webp"
    alt="Yumma CSS"
  />
  <a href="/brand">Trademark Policy</a>
  <p>
    {description}
  </p>

  <slot />
</article>

<style>
  article {
    margin-inline: auto;
    max-width: 40rem;
    padding-block: 5rem;
  }

  article > :global(*) {
    margin-top: 0 !important;
    max-width: 50ch;
  }

  small {
    color: var(--sl-color-gray-3);
  }
</style>
